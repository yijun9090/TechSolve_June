# Copy this file to .env and fill in your real key. .env is gitignored — never commit it.

# Claude API key. Either variable name works (CLAUDE_API_KEY is checked first,
# falls back to ANTHROPIC_API_KEY, which is the LangChain/Anthropic SDK default).
CLAUDE_API_KEY=

# Optional: override the default model used by the AI Operations Assistant.
# CLAUDE_MODEL=claude-sonnet-4-6
